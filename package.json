{
  "name": "LMS",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "pretty": "pnpm format && pnpm lint",
    "seed:course": "node --env-file=.env seed/course/index.mjs",
    "seed:course-section": "node --env-file=.env seed/course-section/index.mjs",
    "seed:group": "node --env-file=.env seed/group/index.mjs",
    "seed:schedule": "node --env-file=.env seed/schedule/index.mjs",
    "seed:student": "node --env-file=.env seed/student/index.mjs",
    "seed:teacher": "node --env-file=.env seed/teacher/index.mjs",
    "sync": "lingui extract --overwrite",
    "sync_and_purge": "lingui extract --overwrite --clean",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.5",
    "@hookform/resolvers": "^5.2.2",
    "@lingui/core": "^5.5.0",
    "@lingui/format-po": "^5.7.0",
    "@lingui/react": "^5.5.0",
    "@number-flow/react": "^0.5.10",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-form": "^1.23.0",
    "@tanstack/react-hotkeys": "^0.3.1",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-router": "^1.139.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.121.2",
    "@types/react-dnd": "^3.0.2",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "husky": "^9.1.7",
    "input-otp": "^1.4.2",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.476.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.11.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.0.0",
    "react-hls-player": "^3.0.7",
    "react-hook-form": "^7.66.1",
    "react-intersection-observer": "^9.16.0",
    "react-resizable-panels": "^3.0.6",
    "react-selecto": "^1.26.3",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.6",
    "tus-js-client": "^4.3.1",
    "tw-animate-css": "^1.3.6",
    "vaul": "^1.1.2",
    "ymap3-components": "^1.2.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@lingui/babel-plugin-lingui-macro": "^5.5.0",
    "@lingui/cli": "^5.5.0",
    "@lingui/vite-plugin": "^5.5.0",
    "@siberiacancode/eslint": "2.12.0",
    "@siberiacancode/prettier": "^1.4.0",
    "@tanstack/eslint-plugin-query": "^5.90.1",
    "@tanstack/eslint-plugin-router": "^1.131.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "9.36.0",
    "eslint-plugin-lingui": "^0.11.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.7.2",
    "vite": "^7.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
